##################################################
# LibxaFrame — Environment Configuration
##################################################

APP_NAME="LibxaFrame App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

##################################################
# Server
##################################################

SERVER_HOST=127.0.0.1
SERVER_PORT=8000

##################################################
# Database
##################################################

DB_DRIVER=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

# Read/Write Splitting (optional)
DB_READ_HOST=
DB_WRITE_HOST=

##################################################
# Atlas ORM
##################################################

ATLAS_AI_ENABLED=false
ATLAS_AI_PROVIDER=openai
ATLAS_AI_KEY=
ATLAS_AI_MODEL=gpt-4o-mini
ATLAS_AI_READ_ONLY=true
ATLAS_QUERY_LOG=true

##################################################
# Cache
##################################################

CACHE_DRIVER=file
CACHE_PREFIX=Libxa_
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

##################################################
# Queue
##################################################

QUEUE_CONNECTION=sync

##################################################
# WebSocket (Workerman)
##################################################

WS_HOST=0.0.0.0
WS_PORT=8080
WS_WORKERS=4
WS_SSL=false
WS_SSL_CERT=
WS_SSL_KEY=

##################################################
# Session
##################################################

SESSION_DRIVER=file
SESSION_LIFETIME=120

##################################################
# Mail
##################################################

MAIL_DRIVER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=hello@Libxaframe.dev
MAIL_FROM_NAME="${APP_NAME}"

##################################################
# Multi-Tenancy
##################################################

TENANCY_ENABLED=false
TENANCY_STRATEGY=separate_database
TENANCY_RESOLVER=subdomain

##################################################
# Security
##################################################

CSRF_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60
